<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # ----------------------------------------------------------------------
    # Pass Authorization headers to PHP
    # ----------------------------------------------------------------------
    SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
    CGIPassAuth On

    # Handle SPA routing - relative to wherever .htaccess is placed
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    # Exclude the backend/api directory from frontend routing (wildcard match)
    RewriteCond %{REQUEST_URI} !/backend/api/
    RewriteRule ^ index.html [QSA,L]
</IfModule>
